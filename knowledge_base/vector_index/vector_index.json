    },
    {
      "chunk_id": "b815aa9e_20260605_chunk_38",
      "file_id": "b815aa9e_20260605",
      "file_name": "流程类八股.pdf",
      "content": "则自己尝试加载\n            }\n            if (c == null) {\n                c = findClass(name); // 自己加载\n            }\n        }\n        if (resolve) resolveClass(c);\n        return c;\n    }\n}\n3.",
